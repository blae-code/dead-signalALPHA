APP_ENV=production
MONGO_URL=mongodb://localhost:27017
DB_NAME=dead_signal
JWT_SECRET=replace-with-a-long-random-secret
SETUP_SECRET=replace-with-a-one-time-bootstrap-secret

# Browser auth / reverse proxy
CORS_ORIGINS=https://dead-signal.example.com
COOKIE_SECURE=true
COOKIE_SAMESITE=none
# COOKIE_DOMAIN=example.com

# Optional debug behavior
RETURN_AUTH_TOKENS=false
WRITE_DEBUG_CREDENTIALS=false

# Optional filesystem override for debug credential output
# MEMORY_DIR=/app/memory

# Pterodactyl integration
PTERODACTYL_URL=https://panel.example.com
PTERODACTYL_API_KEY=replace-with-pterodactyl-client-api-key
PTERODACTYL_SERVER_ID=replace-with-server-id

# AI narration
EMERGENT_LLM_KEY=replace-with-emergent-llm-key
